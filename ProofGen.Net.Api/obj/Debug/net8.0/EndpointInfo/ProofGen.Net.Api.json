{
  "openapi": "3.0.1",
  "info": {
    "title": "Ticket OCR API",
    "version": "v1"
  },
  "paths": {
    "/api/ticket/pdf": {
      "post": {
        "tags": [
          "PDF"
        ],
        "operationId": "GenerarPdfTicket",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Ticket"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/tickets/extraer": {
      "post": {
        "tags": [
          "Tickets"
        ],
        "operationId": "ExtraerTicket",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Ticket"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "nullable": true
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "discount": {
            "type": "number",
            "format": "double"
          },
          "ammount": {
            "type": "number",
            "format": "double"
          },
          "quantity": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "Ticket": {
        "type": "object",
        "properties": {
          "legalName": {
            "type": "string",
            "nullable": true
          },
          "federalTaxpayerRegistry": {
            "type": "string",
            "nullable": true
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "hours": {
            "type": "string",
            "nullable": true
          },
          "idFolder": {
            "type": "string",
            "nullable": true
          },
          "cashier": {
            "type": "string",
            "nullable": true
          },
          "checkOut": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "totalAmount": {
            "type": "number",
            "format": "double"
          },
          "card": {
            "type": "number",
            "format": "double"
          },
          "change": {
            "type": "number",
            "format": "double"
          },
          "products": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Product"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}